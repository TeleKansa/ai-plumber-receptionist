OPENAI_API_KEY=replace-with-openai-api-key

TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567
PLUMBER_PHONE_NUMBER=+15557654321

# Public HTTPS hostname used by Twilio to reach this app.
# Example: ai-plumber-receptionist-production.up.railway.app
HOST=replace-with-public-hostname
PUBLIC_HOST=replace-with-public-hostname

# OpenAI Realtime WebSocket URL.
OAI_URL=wss://api.openai.com/v1/realtime?model=gpt-realtime-1.5
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime?model=gpt-realtime-1.5

# Durable lead storage. Railway should use Postgres here.
# Local/dev can omit this to use the SQLite fallback.
DATABASE_URL=postgresql://user:password@host:5432/database

# Required to enable /admin in deployed environments.
ADMIN_PASSWORD=replace-with-a-long-random-password

# Optional default tenant bootstrap values.
DEFAULT_TENANT_NAME=Default Plumbing
DEFAULT_TENANT_SLUG=default
DEFAULT_TENANT_GREETING=Plumbing office, what's going on?
